# === Required ===
# (none — Hoot works with zero config)

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=your-bot-token-here
AUTHORIZED_USER_ID=123456789

# === Server ===
API_PORT=7777

# === Model ===
COPILOT_MODEL=claude-sonnet-4.5

# === Feature Flags ===
MAX_QUEUE_V2=1
MAX_POOL_ENABLED=1
MAX_ENCRYPT_DB=0
MAX_LOG_FORMAT=json
MAX_PLUGINS_ENABLED=0

# === Advanced ===
WORKER_TIMEOUT=600000
MAX_TUI_DEBUG=0
